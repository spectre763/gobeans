# Owner dashboard password (change in production)
OWNER_PASSWORD=gobeans2024

# Session secret for admin cookie (change in production)
ADMIN_SECRET=gobeans-admin-dev-secret

# ── Email (choose one provider) ──────────────────────────────

# Option 1: Resend (recommended for Vercel — free tier: 100 emails/day)
# Sign up at https://resend.com → create API key → verify your domain
RESEND_API_KEY=
RESEND_FROM=GoBeans <hello@gobeans.in>

# Option 2: SMTP (Gmail, Outlook, etc.)
# Gmail: use an App Password → https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=hello@gobeans.in

# Without either provider, emails are saved locally to data/email-outbox.json (dev only)

# ── Redis (required on Vercel for booking storage) ───────────
REDIS_URL=
